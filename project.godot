; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Hot Pickle"
run/main_scene="res://src/UserInterface/Title Screen.tscn"
config/features=PackedStringArray("4.2")
boot_splash/image="res://assets/art/UI/Ben Stark Studios.png"
config/icon="res://icon.png"
config/Version="0.3.0"

[autoload]

AudioManager="*res://src/AudioManager.gd"
Main="*res://src/Main.gd"
UserData="*res://addons/github-integration/scripts/user_data.gd"
IconLoaderGithub="*res://addons/github-integration/scripts/IconLoaderGithub.gd"
RestHandler="*res://addons/github-integration/scripts/RestHandler.gd"

[display]

window/stretch/mode="viewport"
window/size/width=1920
window/size/height=1080

[editor_plugins]

enabled=PackedStringArray("github-integration")

